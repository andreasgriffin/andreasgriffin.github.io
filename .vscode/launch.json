{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hugo Server (clean)",
      "type": "node-terminal",
      "request": "launch",
      "command": "hugo server --cleanDestinationDir",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Web Server is available at (http://localhost:1313/)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
